{
  "name": "ratnation",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "fix": "eslint . --fix",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest --coverage --verbose"
  },
  "dependencies": {
    "chalk-template": "1.x",
    "delay": "6.x",
    "execa": "9.x",
    "find-my-way": "9.x",
    "got": "14.x",
    "is-port-reachable": "4.x",
    "p-wait-for": "6.x",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "source-map-support": "0.5.x",
    "split2": "4.x",
    "yargs": "17.x"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "30.x",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/node": "22.x",
    "@types/split2": "4.x",
    "@types/supertest": "6.x",
    "eslint": "10.x",
    "jest": "30.x",
    "jiti": "^2.6.1",
    "supertest": "7.x",
    "ts-jest": "29.x",
    "typescript": "5.x",
    "typescript-eslint": "^8.56.0",
    "wait-for-expect": "4.x"
  },
  "engines": {
    "node": ">=18"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,js}",
      "!src/index.{ts,js}"
    ],
    "coverageReporters": [
      "text-summary",
      "json-summary",
      "lcov"
    ]
  }
}
